---
# ansible-lint configuration
profile: production

exclude_paths:
  - .cache/
  - .ansible/

# All ansible-lint rules fixed — production profile passes with 0 warnings.
# Fixed rules (in order):
# schema, key-order, jinja, command-instead-of-module, partial-become,
# name[casing], name[missing], name[template], literal-compare, no-free-form,
# var-naming, yaml[indentation], yaml[document-start], yaml[comments],
# yaml[comments-indentation], latest, risky-octal, meta-no-tags,
# no-changed-when, ignore-errors, fqcn, risky-file-permissions
