---
# ansible-lint configuration
profile: moderate

exclude_paths:
  - .cache/
  - .ansible/

# Rules to promote from error → warning (work through incrementally).
# Items marked FIXED ✓ have been fully resolved.
warn_list:
  # Production-profile (safety) rules — to be fixed one by one:
  - risky-file-permissions  # 52 violations — add mode: to file/copy/template tasks
  - ignore-errors        # 7 violations — avoid ignore_errors where possible
  - fqcn                 # 36 violations — use fully-qualified collection names
  # latest: FIXED ✓
  # risky-octal: FIXED ✓
  # meta-no-tags: FIXED ✓
  # no-changed-when: FIXED ✓

  # Previously fixed (kept for reference):
  # schema: FIXED ✓
  # key-order: FIXED ✓
  # jinja: FIXED ✓
  # command-instead-of-module: FIXED ✓
  # partial-become: FIXED ✓
  # name[casing]: FIXED ✓
  # name[missing]: FIXED ✓
  # name[template]: FIXED ✓
  # literal-compare: FIXED ✓
  # no-free-form: FIXED ✓
  # var-naming: FIXED ✓
  # yaml[indentation]: FIXED ✓
  # yaml[document-start]: FIXED ✓
  # yaml[comments]: FIXED ✓
  # yaml[comments-indentation]: FIXED ✓
