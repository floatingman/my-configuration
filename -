    - { role: dotfiles, tags: ["dotfiles"], when: dotfiles is defined }
    - { role: goesimage, tags: ["goesimage"], when: _has_display and goesimage is defined }
    - { role: regdomain, tags: ["regdomain"], when: regdomain is defined }
