    # GPU Detection & Drivers (Arch-only)
    # -------------------------------------------------------------------------
    - { role: gpu_detect, tags: ["gpu_detect"], when: _is_arch }
    - { role: gpu_drivers, tags: ["gpu_drivers"], when: _is_arch }
    # -------------------------------------------------------------------------
    # Base System (Arch-only)
    # -------------------------------------------------------------------------
    - { role: base, tags: ["base"], when: _is_arch }
    - { role: grub, tags: ["grub"], when: _is_arch }
    - { role: microcode, tags: ["microcode"], when: _is_arch }
    # -------------------------------------------------------------------------
    # Universal System Configuration
    # -------------------------------------------------------------------------
    - { role: archive, tags: ["archive"] }
    - { role: cron, tags: ["cron"] }
    - { role: gnupg, tags: ["gnupg"] }
    - { role: shell, tags: ["shell"] }
    - { role: ssh, tags: ["ssh"] }
    - { role: sysmon, tags: ["sysmon"] }
    - { role: system, tags: ["system"] }
    # -------------------------------------------------------------------------
    # Package Management
    # -------------------------------------------------------------------------
    - { role: ansible-role-asdf, tags: ["asdf"] }
    - { role: ansible-role-binaries, tags: ["binaries"], when: not _is_arch }
    - { role: ansible-role-packages, tags: ["packages"] }
    - { role: aur, tags: ["aur"], when: _is_arch }
    - { role: flatpak, tags: ["flatpak"] }
    - { role: golang, tags: ["golang"], when: not _is_arch }
    - { role: homebrew, tags: ["homebrew"], when: not _is_arch }
    # -------------------------------------------------------------------------
    # Development Tools
    # -------------------------------------------------------------------------
    - { role: devtools, tags: ["devtools"], when: _is_arch and _has_display }
    - { role: docker, tags: ["docker"], when: _is_arch }
    - { role: editors, tags: ["editors"] }
    - { role: filesystem, tags: ["filesystem"] }
    - { role: kubernetes, tags: ["kubernetes"], when: _is_arch }
    - { role: python, tags: ["python"] }
    - { role: rust, tags: ["rust"] }
    # -------------------------------------------------------------------------
    # Networking (Arch-only)
    # -------------------------------------------------------------------------
    - { role: filesharing, tags: ["filesharing"], when: _is_arch }
    - { role: mirrorlist, tags: ["mirrorlist"], when: _is_arch }
    - { role: nettools, tags: ["nettools"], when: _is_arch }
    - { role: networkmanager, tags: ["networkmanager"], when: _is_arch and _has_display }
    - { role: nmtrust, tags: ["nmtrust"], when: _is_arch and _has_display }
    # -------------------------------------------------------------------------
    # Productivity & Utilities
    # -------------------------------------------------------------------------
    - { role: clipboard, tags: ["clipboard"], when: _is_arch }
    - { role: clouddrive, tags: ["clouddrive"], when: _is_arch }
    - { role: pass, tags: ["pass"], when: _is_arch }
    - { role: spell, tags: ["spell"] }
    - { role: syncthing, tags: ["syncthing"] }
    - { role: taskwarrior, tags: ["taskwarrior"], when: _is_arch }
    # -------------------------------------------------------------------------
