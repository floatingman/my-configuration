- name: Configure localhost
  hosts: localhost

  pre_tasks:
    - name: Resolve unified role manifest
      command: >-
        {{ ansible_playbook_python | default(ansible_python_interpreter) | default('/usr/bin/python3') }}
        {{ playbook_dir }}/scripts/profile_dispatcher.py resolve-role-manifest
        --profiles-dir "{{ playbook_dir }}/profiles"
        --profile "{{ profile | default('manual') }}"
        --os-family "{{ ansible_facts['os_family'] }}"
        {{ (display_manager is defined) | ternary('--display-manager "' ~ (display_manager | default('')) ~ '"', '') }}
        {{ (desktop_environment is defined) | ternary('--desktop-environment "' ~ (desktop_environment | default('')) ~ '"', '') }}
        {{ (disable_i3 is defined and disable_i3) | ternary('--disable-i3', '') }}
        {{ (disable_hyprland is defined and disable_hyprland) | ternary('--disable-hyprland', '') }}
        {{ (disable_gnome is defined and disable_gnome) | ternary('--disable-gnome', '') }}
        {{ (disable_awesomewm is defined and disable_awesomewm) | ternary('--disable-awesomewm', '') }}
        {{ (disable_kde is defined and disable_kde) | ternary('--disable-kde', '') }}
        --host-vars '{{ _host_vars_json }}'
      vars:
        _host_vars_json: >-
          {{
            {}
            | combine({"bluetooth": bluetooth} if bluetooth is defined else {})
            | combine({"laptop": laptop} if laptop is defined else {})
            | to_json
          }}
      register: _manifest_result
      changed_when: false
      check_mode: false
      tags: always

    - name: Set profile facts from resolved manifest
      vars:
        _manifest: "{{ _manifest_result.stdout | from_json }}"
        _pf: "{{ _manifest.profile_flags }}"
      set_fact:
        _profile: "{{ _manifest.profile }}"
        _dm: "{{ _pf._dm | default('', true) }}"
        _has_display: "{{ _pf._has_display }}"
        _is_i3: "{{ _pf._is_i3 }}"
        _is_hyprland: "{{ _pf._is_hyprland }}"
        _is_gnome: "{{ _pf._is_gnome }}"
        _is_awesomewm: "{{ _pf._is_awesomewm }}"
        _is_kde: "{{ _pf._is_kde }}"
        _is_arch: "{{ _pf._is_arch }}"
      tags: always

    - name: Set overlay facts from resolved manifest
      vars:
        _manifest: "{{ _manifest_result.stdout | from_json }}"
        _of: "{{ _manifest.overlay_flags }}"
      set_fact:
        _overlay_laptop: "{{ _of._overlay_laptop | default(false) }}"
        _overlay_backlight: "{{ _of._overlay_backlight | default(false) }}"
        _overlay_bluetooth: "{{ _of._overlay_bluetooth | default(false) }}"
        _overlay_dotfiles: "{{ _of._overlay_dotfiles | default(false) }}"
        _overlay_goesimage: "{{ _of._overlay_goesimage | default(false) }}"
        _overlay_regdomain: "{{ _of._overlay_regdomain | default(false) }}"
      tags: always

  roles:
