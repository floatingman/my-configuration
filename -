    - { role: browsers, tags: ["browsers"], when: _has_display }
    - { role: cups, tags: ["cups"], when: _is_arch and _has_display }
    - { role: filemanager, tags: ["filemanager"], when: _has_display }
    - { role: media, tags: ["media"], when: _has_display }
    - { role: mpd, tags: ["mpd"], when: _has_display }
    - { role: mpv, tags: ["mpv"], when: _has_display }
    - { role: notes, tags: ["notes"], when: _has_display }
    - { role: proton, tags: ["proton"], when: _has_display }
    - { role: screensaver, tags: ["screensaver"], when: _has_display }
    - { role: sound, tags: ["sound"], when: _has_display }
    - { role: terminal, tags: ["terminal"], when: _has_display }
    - { role: twitch, tags: ["twitch"], when: _has_display }
    - { role: udisks, tags: ["udisks"], when: _is_arch and _has_display }
    # -------------------------------------------------------------------------
    # Optional / Feature-gated
