    # -------------------------------------------------------------------------
    - { role: lightdm, tags: ["lightdm"], when: _has_display and _dm == 'lightdm' }
    - { role: gdm, tags: ["gdm"], when: _has_display and _dm == 'gdm' }
    # -------------------------------------------------------------------------
    # Profile: i3 (X11 tiling window manager)
    # -------------------------------------------------------------------------
    - { role: x, tags: ["x"], when: _is_awesomewm or _is_gnome or _is_i3 or _is_kde }
    - { role: i3, tags: ["i3"], when: _is_i3 }
    # -------------------------------------------------------------------------
    # Profile: Hyprland (Wayland compositor)
    # -------------------------------------------------------------------------
    - { role: hyprland, tags: ["hyprland"], when: _is_hyprland }
    - { role: microtex, tags: ["microtex"], when: _is_hyprland }
    - { role: oneui4_icons, tags: ["oneui4_icons"], when: _is_hyprland }
    - { role: qt_gtk_toolkit, tags: ["qt_gtk_toolkit"], when: _is_hyprland }
    - { role: screencapture, tags: ["screencapture"], when: _is_hyprland }
    - { role: uv_python_packages, tags: ["uv_python_packages"], when: _is_hyprland }
    - { role: wayland, tags: ["wayland"], when: _is_hyprland }
    - { role: widgets, tags: ["widgets"], when: _is_hyprland }
